class chatConversation {
	private ArrayList<String> members;
	private String adminIp;
	private String chatName;

	public chatConversation(String adminIp) {
		members = new ArrayList<String>();
		this.adminIp = adminIp;
		members.add(adminIp);
	}

	public ArrayList<String> getMembers() {
		return members;
	}

	public String getName() {
		return chatName;
	}

	public int addMember(String newMember) {
		int sameCount = 0;
		for (String s : members) {
			if (s == newMember) {
				sameCount++;
			}
		}
		if (sameCount == 0) {
			members.add(newMember);
			return 0;
		}
		return -1;
	}

	public int removeMember(String removeMember, String Requester) {
		if (Requester != adminIp) {
			return -2;
		}
		int sameCount = 0;
		for (String s : members) {
			if (s == removeMember) {
				sameCount++;
			}
		}
		if (sameCount > 1) {
			members.remove(removeMember);
			return 0;
		}
		return -1;
	}

}
