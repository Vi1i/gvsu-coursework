import java.io.*;
import java.net.*;
import java.util.ArrayList;

class tcpserver {
	private ArrayList<chatConversation> currentChats;

	BufferedReader inFromClient;

	public static void main(String argv[]) throws Exception {
		Socket connectionSocket;
		ServerSocket listenSocket = new ServerSocket(9876);
		recieveFromClient recieve;
		SendToClient send;

		while (true) {
			connectionSocket = listenSocket.accept();
			recieve = new recieveFromClient(connectionSocket);
			send = new SendToClient(connectionSocket);
			Thread recieveThread = new Thread(recieve);
			Thread sendThread = new Thread(send);
			recieveThread.start();
			sendThread.start();

		}
	}
}

class recieveFromClient implements Runnable {
	Socket connectionSocket;
	string inMessage;

	public recieveFromClient(Socket connectionSocket) {
		this.connectionSocket = connectionSocket;
	}

	public void run() {
		BufferedReader inFromClient = new BufferedReader(new InputStreamReader(
				connectionSocket.getInputStream()));
		inMessage = inFromClient.readLine();
		System.out.println("Got from client" + inMessage);
	}
}

