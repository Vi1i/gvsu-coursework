class recieveFromClient implements Runnable {
	Socket connectionSocket;
	String inMessage;

	public recieveFromClient(Socket connectionSocket) {
		this.connectionSocket = connectionSocket;
	}

	public void run() {
		BufferedReader inFromClient = new BufferedReader(new InputStreamReader(
				connectionSocket.getInputStream()));
		while(true){
			inMessage = inFromClient.readLine();
			
			if(inMessage!= null){
				if(inMessage =="Exit"){
					System.out.println("Client left");
					break;
				}
				System.out.println("Got from client" + inMessage);
			}
		}
	}
}

class SendToClient implements Runnable {
	Socket connectionSocket;
	DataOutputStream outToClient;

	public SendToClient(Socket connectionSocket) {
		this.connectionSocket = connectionSocket;
	}

	public void run() {
		outToClient = new DataOutputStream(connectionSocket.getOutputStream());
		outToClient.writeBytes("Test");
	}
}

class chatConversation {
	private ArrayList<String> members;
	private String adminIp;
	private String chatName;

	public chatConversation(String adminIp) {
		members = new ArrayList<String>();
		this.adminIp = adminIp;
		members.add(adminIp);
	}

	public ArrayList<String> getMembers() {
		return members;
	}

	public String getName() {
		return chatName;
	}

	public int addMember(String newMember) {
		int sameCount = 0;
		for (String s : members) {
			if (s == newMember) {
				sameCount++;
			}
		}
		if (sameCount == 0) {
			members.add(newMember);
			return 0;
		}
		return -1;
	}

	public int removeMember(String removeMember, String Requester) {
		if (Requester != adminIp) {
			return -2;
		}
		int sameCount = 0;
		for (String s : members) {
			if (s == removeMember) {
				sameCount++;
			}
		}
		if (sameCount > 1) {
			members.remove(removeMember);
			return 0;
		}
		return -1;
	}

}
